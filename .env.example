# ---------- General ----------
NODE_ENV=development
CLIENT_URL=http://localhost:5173
SERVER_PORT=5000

# ---------- Database ----------
MONGO_URI=mongodb://localhost:27017/nexuschat
# Optional: enables Socket.io multi-instance broadcast. Leave unset for single-instance local dev.
REDIS_URL=

# ---------- JWT ----------
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_REMEMBER_REFRESH_EXPIRES_IN=90d

# ---------- Email (SMTP) ----------
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="ChatiHive <no-reply@chatihive.app>"

# ---------- Google OAuth (optional, leave blank to disable) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ---------- Cloudinary ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- Firebase Cloud Messaging (optional) ----------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---------- Security ----------
COOKIE_SECRET=change_me_cookie_secret
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ---------- Frontend (Vite, must be prefixed VITE_) ----------
VITE_API_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
